# ============================================================
# CONSULTO — Variables d'environnement
# Copier ce fichier en .env.local et remplir avec tes propres clés
# ============================================================

# --- Supabase (base de données + authentification + stockage) ---
# À récupérer sur https://supabase.com après création du projet
# Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (paiement + séquestre) ---
# À récupérer sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (envoi d'emails transactionnels) ---
# À récupérer sur https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@1expert.fr

# --- Application ---
NEXT_PUBLIC_SITE_URL=https://1expert.fr
